{
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "framework": "express",
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/login", "destination": "/api/server" },
    { "source": "/logout", "destination": "/api/server" },
    { "source": "/admin-session", "destination": "/api/server" },
    { "source": "/inventory", "destination": "/api/server" },
    { "source": "/inventory/:id", "destination": "/api/server" },
    { "source": "/rentals", "destination": "/api/server" },
    { "source": "/reports", "destination": "/api/server" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
